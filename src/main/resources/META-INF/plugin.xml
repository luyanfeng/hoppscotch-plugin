<idea-plugin>
    <id>com.hoppscotch.sync</id>
    <name>Hoppscotch Sync</name>
    <version>1.2.1</version>
    <vendor email="support@hoppscotch.io" url="https://github.com/hoppscotch/hoppscotch">
        Hoppscotch Sync
    </vendor>

    <description>
        <![CDATA[
            <p>A plugin that syncs Spring Boot REST API endpoints to Hoppscotch Self-Hosted.</p>
            <p><b>⚠️ Spring Boot (Java) only.</b> Go, Node.js, Python and other languages/frameworks are not supported.</p>
            <p>Features:</p>
            <ul>
                <li>Parse @RestController and @Controller classes</li>
                <li>Extract HTTP mapping annotations (@RequestMapping, @GetMapping, etc.)</li>
                <li>Sync endpoints to Hoppscotch via GraphQL API</li>
                <li>Multi-project/module support in a single IDEA window</li>
                <li>Selective sync with checkbox selection</li>
                <li>Search and filter by project name</li>
            </ul>
        ]]>
    </description>

    <change-notes>
        <![CDATA[
            <ul>
                <li><b>1.0.0</b> Initial release</li>
            </ul>
        ]]>
    </change-notes>

    <idea-version since-build="261" until-build="262.*"/>

    <depends>com.intellij.java</depends>
    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.HoppscotchSyncBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="com.hoppscotch.sync.service.TokenRefreshStartupActivity"/>

        <toolWindow
                id="Hoppscotch Sync"
                anchor="right"
                secondary="true"
                factoryClass="com.hoppscotch.sync.toolwindow.HoppscotchSyncToolWindowFactory"/>

        <applicationService
                serviceImplementation="com.hoppscotch.sync.settings.AppSettings"/>

        <applicationConfigurable
                parentId="tools"
                instance="com.hoppscotch.sync.settings.AppSettingsConfigurable"
                id="com.hoppscotch.sync.settings.AppSettingsConfigurable"
                displayName="Hoppscotch Sync"/>
    </extensions>

    <actions>
        <action
                id="com.hoppscotch.sync.action.SyncAction"
                class="com.hoppscotch.sync.action.SyncAction"
                text="Sync Spring Boot Endpoints to Hoppscotch"
                description="Parse Spring Boot controllers and sync endpoints to Hoppscotch">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
